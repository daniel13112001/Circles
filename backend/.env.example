# Copy to .env and fill in your values.
# Never commit .env or anything inside secrets/ to git.
#
# Running via Docker Compose (from repo root)?
# You only need FIREBASE_PROJECT_ID — copy .env.example at the repo root instead.
#
# Running `go run ./cmd/api` directly? Fill everything below.

# PostgreSQL — use Supabase session pooler URL (port 6543), or your own Postgres instance
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Firebase
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_FILE=./secrets/firebase-service-account.json

# API
PORT=8080
